{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A chat room or channel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["public", "private"] }
      },
      "required": ["name", "createdBy", "createdAt", "type"]
    },
    "Message": {
      "title": "Message",
      "description": "A message sent in a channel",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["channelId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/channels/{channelId}": {
      "schema": "Channel",
      "description": "Chat channels"
    },
    "/channels/{channelId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a channel"
    }
  }
}
